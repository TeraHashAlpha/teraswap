# ══════════════════════════════════════════════════════════════
# TeraSwap — Environment Configuration Template
# ══════════════════════════════════════════════════════════════
#
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# All NEXT_PUBLIC_ vars are exposed to the browser.
# Keys WITHOUT NEXT_PUBLIC_ are server-only (API routes only).
# ══════════════════════════════════════════════════════════════

# ── Chain ──────────────────────────────────────────────────────
# 1 = Ethereum mainnet, 11155111 = Sepolia testnet
CHAIN_ID=1

# ── RPC ───────────────────────────────────────────────────────
# Primary RPC — use Alchemy or Infura for production reliability
NEXT_PUBLIC_RPC_URL=https://eth.llamarpc.com

# Fallback RPCs — automatic failover when primary is down
NEXT_PUBLIC_FALLBACK_RPC_1=https://rpc.ankr.com/eth
NEXT_PUBLIC_FALLBACK_RPC_2=https://ethereum-rpc.publicnode.com

# ── Aggregator API Keys (server-only) ─────────────────────────
# These are NOT exposed to the browser. Only used in API routes.
# 1inch — get from https://portal.1inch.dev
ONEINCH_API_KEY=
# 0x — get from https://0x.org/docs
ZEROX_API_KEY=

# ── WalletConnect ─────────────────────────────────────────────
# Get free at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ── Fees ──────────────────────────────────────────────────────
# Your wallet address for fee collection (MUST be a real address, not zero)
NEXT_PUBLIC_FEE_RECIPIENT=
# Fee percentage (0.1 = 0.1%)
NEXT_PUBLIC_FEE_PERCENT=0.1
# FeeCollector smart contract address (deploy contracts/TeraSwapFeeCollector.sol)
NEXT_PUBLIC_FEE_COLLECTOR=

# ── Supabase (public — browser-safe) ─────────────────────────
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Supabase (server-only — API routes) ──────────────────────
# NEVER expose the service role key to the browser!
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Order Engine ──────────────────────────────────────────────
# TeraSwapOrderExecutor contract address (set after deployment)
NEXT_PUBLIC_ORDER_EXECUTOR_ADDRESS=

# ── Admin ─────────────────────────────────────────────────────
# Wallet address for admin dashboard access
NEXT_PUBLIC_ADMIN_WALLET=

# ── Health Endpoint ───────────────────────────────────────────
# Token to protect /api/health from unauthorized access
HEALTH_TOKEN=

# ── Flashbots (optional) ─────────────────────────────────────
# MEV-protected transaction submission (mainnet only)
# FLASHBOTS_RPC_URL=https://rpc.flashbots.net

# ── Launch Countdown (optional) ───────────────────────────────
# Set to an ISO-8601 date to show a countdown before launch.
# Remove or leave empty to go live immediately.
# NEXT_PUBLIC_LAUNCH_DATE=2026-03-15T12:00:00Z

# ── Error Monitoring (Sentry) ─────────────────────────────────
# Get free at https://sentry.io → Create project (Next.js) → copy DSN
NEXT_PUBLIC_SENTRY_DSN=

# ── Vercel KV (Rate Limiting + Source State + Monitoring) ────
# Required for:
#   - Persistent rate limiting across serverless instances
#   - Source state machine (H1/H2 health monitoring)
#   - Monitor heartbeat (dead-man's switch)
# Create at: Vercel Dashboard → Storage → KV → Create
# If not set, rate limiting and monitoring fail open.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Monitoring Cron ──────────────────────────────────────────
# Shared secret between the Cloudflare Worker scheduler and /api/monitor/tick.
# Generate via: openssl rand -hex 32
# Must match the secret set on the Worker (wrangler secret put MONITOR_CRON_SECRET).
# MONITOR_CRON_SECRET=

# ── Monitoring Alerts ────────────────────────────────────────
# Alert channels for source state transitions. All optional — channels with
# missing env vars are silently skipped (graceful degradation).

# Telegram Bot API (primary channel)
# Create bot via @BotFather, get chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email via Resend (secondary channel)
# Sign up at https://resend.com, verify your domain
RESEND_API_KEY=
ALERT_EMAIL_TO=

# Discord webhook (tertiary channel)
# Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=

# Grace period — suppress alerts during planned maintenance.
# Set to an ISO 8601 timestamp (e.g., 2026-04-16T02:00:00Z).
# Exception: kill-switch alerts ALWAYS fire regardless of grace.
# Also forces /api/monitor/heartbeat to report healthy (watchdog won't page).
# Leave empty for no grace period.
MONITOR_GRACE_UNTIL=

# ── External Watchdog ────────────────────────────────────────
# GitHub Actions polls GET /api/monitor/heartbeat every 5 min.
# If the heartbeat is stale (>3 min), it sends an alert to this webhook.
# Set in GitHub repo Settings → Secrets → WATCHDOG_ALERT_WEBHOOK.
# Supports Telegram bot webhook or Discord webhook URL.
# WATCHDOG_ALERT_WEBHOOK= (GitHub Secret, not set here)
