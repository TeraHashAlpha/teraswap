# ── RPC ──────────────────────────────────────────────────
# Primary RPC — for production, use Alchemy or Infura for reliability
NEXT_PUBLIC_RPC_URL=https://eth.llamarpc.com

# Fallback RPCs — automatic failover when primary is down
# The system ranks providers by latency and uses the fastest available
NEXT_PUBLIC_FALLBACK_RPC_1=https://rpc.ankr.com/eth
NEXT_PUBLIC_FALLBACK_RPC_2=https://ethereum-rpc.publicnode.com

# ── Aggregator API Keys ─────────────────────────────────
# 1inch — get from https://portal.1inch.dev (optional, uses public endpoint)
NEXT_PUBLIC_1INCH_API_KEY=

# 0x — get from https://0x.org/docs (optional, uses public endpoint)
NEXT_PUBLIC_0X_API_KEY=

# ── Wallet ───────────────────────────────────────────────
# WalletConnect — get free at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ── Fees ─────────────────────────────────────────────────
# Your wallet address for fee collection
NEXT_PUBLIC_FEE_RECIPIENT=0x0000000000000000000000000000000000000000
# Fee percentage (0.1 = 0.1%)
NEXT_PUBLIC_FEE_PERCENT=0.1

# ── Launch Countdown (optional) ─────────────────────────
# Set to an ISO-8601 date to show a countdown before launch.
# Remove or leave empty to go live immediately.
# NEXT_PUBLIC_LAUNCH_DATE=2026-03-02T12:00:00Z

# ── Supabase (optional — for 24/7 analytics persistence) ─
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
