# ── TeraSwap Order Executor — Configuration ──────────────────
# Copy this file to .env.executor and fill in your values.
# NEVER commit .env.executor to git!

# ── RPC ──────────────────────────────────────────────────────
# Use a reliable RPC provider (Alchemy, Infura, etc.)
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# ── Executor Wallet ──────────────────────────────────────────
# Private key of the wallet that pays gas for executing orders.
# This wallet needs ETH for gas. It does NOT hold user funds.
#
# [C-02/B-01] SECURITY: For mainnet, use KMS or Vault instead!
#   See kms-signer.js for setup instructions.
#
EXECUTOR_PRIVATE_KEY=0x...

# ── HSM/KMS Configuration (C-02/B-01) ────────────────────────
# When configured, EXECUTOR_PRIVATE_KEY is ignored.
# Priority: KMS > Vault > Plaintext key
#
# AWS KMS — Create ECC_SECG_P256K1 key in AWS KMS Console
# KMS_KEY_ID=arn:aws:kms:us-east-1:123456789:key/your-key-id
# KMS_REGION=us-east-1
#
# HashiCorp Vault — Transit secrets engine
# VAULT_ADDR=https://vault.yourcompany.com
# VAULT_TOKEN=hvs.your-token
# VAULT_KEY_NAME=teraswap-executor

# ── Flashbots Protect RPC (B-02) ─────────────────────────────
# MEV-protected transaction submission (mainnet only).
# FLASHBOTS_RPC_URL=https://rpc.flashbots.net

# ── Health Endpoint Security ─────────────────────────────────
# Protect /health endpoint from unauthorized access
# HEALTH_TOKEN=your-random-secret-token

# ── Supabase (server-side) ───────────────────────────────────
# SERVICE ROLE keys — NOT the anon key!
# [B-06] For production: use Vercel env vars (encrypted)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Contract ─────────────────────────────────────────────────
# TeraSwapOrderExecutor deployed address
ORDER_EXECUTOR_ADDRESS=0xeFC31ADb5d10c51Ac4383bB770E2fdC65780f130

# ── Chain ────────────────────────────────────────────────────
# 1 = Ethereum mainnet, 11155111 = Sepolia
CHAIN_ID=11155111

# ── TeraSwap API (optional) ──────────────────────────────────
# Base URL for the TeraSwap swap route API.
# TERASWAP_API_URL=https://teraswap.io

# ── Monitoring & Alerting ────────────────────────────────────
# Telegram alerts for executor failures and heartbeat.
# Create a bot via @BotFather, get chat ID via @userinfobot.
# If not set, alerting is disabled (monitoring still works).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Prometheus metrics endpoint port (default: 9090)
# METRICS_PORT=9090

# ── Gas Strategy Tiers ──────────────────────────────────────
# Defaults: NORMAL=30, ELEVATED=80, URGENT=100 (gwei)
# GAS_TIER_NORMAL_GWEI=30
# GAS_TIER_ELEVATED_GWEI=80
# GAS_TIER_URGENT_GWEI=100

# ── EIP-1559 Priority Fees (gwei) ──
# GAS_PRIORITY_NORMAL_GWEI=1.5
# GAS_PRIORITY_ELEVATED_GWEI=2.5
# GAS_PRIORITY_URGENT_GWEI=4

# ── Base Fee Multipliers ──
# GAS_BASEFEE_MULT_NORMAL=2
# GAS_BASEFEE_MULT_ELEVATED=2.5
# GAS_BASEFEE_MULT_URGENT=3

# ── Urgency: orders expiring within this window are URGENT ──
# GAS_EXPIRY_URGENCY_S=7200
